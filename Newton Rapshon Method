#include <iostream>
#include <string>
#include <cmath>
#include <cctype>
#include <iomanip>
#include <algorithm>
#include <stdexcept>

using namespace std;

class MathParser {
private:
    string s;
    size_t pos;
    double xVal;

    void skipSpaces() {
        while (pos < s.size() && isspace(static_cast<unsigned char>(s[pos]))) {
            pos++;
        }
    }

    bool match(char c) {
        skipSpaces();
        if (pos < s.size() && s[pos] == c) {
            pos++;
            return true;
        }
        return false;
    }

    double parseNumber() {
        skipSpaces();
        size_t start = pos;
        bool hasDot = false;

        while (pos < s.size() && (isdigit(static_cast<unsigned char>(s[pos])) || s[pos] == '.')) {
            if (s[pos] == '.') {
                if (hasDot) break;
                hasDot = true;
            }
            pos++;
        }

        if (start == pos) {
            return 0;
        }

        string numStr = s.substr(start, pos - start);
        try {
            return stod(numStr);
        } catch (...) {
            return 0;
        }
    }

    double parsePrimary() {
        skipSpaces();

        if (match('(')) {
            double val = parseExpression();
            if (!match(')')) {
                cerr << "Error: Kurung tutup tidak ditemukan" << endl;
            }
            return val;
        }

        // Cek fungsi atau variabel
        if (pos < s.size() && isalpha(static_cast<unsigned char>(s[pos]))) {
            size_t start = pos;
            while (pos < s.size() && isalpha(static_cast<unsigned char>(s[pos]))) {
                pos++;
            }
            string name = s.substr(start, pos - start);

            if (match('(')) {
                double arg = parseExpression();
                if (!match(')')) {
                    cerr << "Error: Kurung tutup tidak ditemukan setelah fungsi" << endl;
                }

                if (name == "sin")   return sin(arg);
                if (name == "cos")   return cos(arg);
                if (name == "tan")   return tan(arg);
                if (name == "log" || name == "ln") return log(arg);
                if (name == "log10") return log10(arg);
                if (name == "exp")   return exp(arg);
                if (name == "sqrt")  return sqrt(arg);
                if (name == "abs")   return abs(arg);

                cerr << "Error: Fungsi tidak dikenal: " << name << endl;
                return 0;
            } else {
                if (name == "x" || name == "X") {
                    return xVal;
                }
                cerr << "Error: Variabel tidak dikenal: " << name << endl;
                return 0;
            }
        }

        if (pos < s.size() && (isdigit(static_cast<unsigned char>(s[pos])) || s[pos] == '.')) {
            return parseNumber();
        }

        return 0;
    }

    double parsePower() {
        double left = parsePrimary();
        while (true) {
            if (match('^')) {
                double right = parsePower(); // Right associative
                left = pow(left, right);
            } else {
                break;
            }
        }
        return left;
    }

    double parseUnary() {
        if (match('+')) {
            return parseUnary();
        }
        if (match('-')) {
            return -parseUnary();
        }
        return parsePower();
    }

    double parseTerm() {
        double left = parseUnary();
        while (true) {
            if (match('*')) {
                double right = parseUnary();
                left *= right;
            } else if (match('/')) {
                double right = parseUnary();
                if (right != 0.0) {
                    left /= right;
                } else {
                    cerr << "Error: Pembagian dengan nol" << endl;
                    return 0;
                }
            } else {
                break;
            }
        }
        return left;
    }

    double parseExpression() {
        double left = parseTerm();
        while (true) {
            if (match('+')) {
                double right = parseTerm();
                left += right;
            } else if (match('-')) {
                double right = parseTerm();
                left -= right;
            } else {
                break;
            }
        }
        return left;
    }

public:
    double evaluate(const string& expr, double xValue) {
        s = expr;
        // Ganti koma dengan titik untuk angka desimal
        for (size_t i = 0; i < s.size(); i++) {
            if (s[i] == ',') s[i] = '.';
        }
        pos = 0;
        xVal = xValue;
        return parseExpression();
    }
};

// Fungsi untuk menghitung turunan numerik menggunakan metode beda hingga
double turunanNumerik(MathParser& parser, const string& fungsi, double x) {
    double h = 1e-7; // nilai h yang sangat kecil
    double fx_plus_h = parser.evaluate(fungsi, x + h);
    double fx = parser.evaluate(fungsi, x);
    return (fx_plus_h - fx) / h;
}

int main() {
    MathParser parser;
    string fungsi;
    string galatStr;
    double x0, galat;

    cout << "============================================================" << endl;
    cout << "           PROGRAM METODE NEWTON-RAPHSON                    " << endl;
    cout << "============================================================" << endl;
    cout << endl;
    cout << "--------------------- PETUNJUK PENGISIAN -------------------" << endl;
    cout << endl;
    cout << "1. CARA MENGISI FUNGSI:" << endl;
    cout << "   - Gunakan 'x' sebagai variabel" << endl;
    cout << "   - Gunakan '*' untuk perkalian (contoh: 2*x, x*x)" << endl;
    cout << "   - Gunakan '^' untuk pangkat (contoh: x^2, x^3)" << endl;
    cout << "   - Gunakan tanda kurung untuk grouping (contoh: (x+1)*(x-2))" << endl;
    cout << "   - Fungsi yang didukung: sin, cos, tan, log, ln, exp, sqrt" << endl;
    cout << "   - Contoh penulisan fungsi:" << endl;
    cout << "     * x^3 - 2*x + 1" << endl;
    cout << "     * sin(x) + x^2 - 4" << endl;
    cout << "     * (x+2)*(x-3) + 5" << endl;
    cout << "     * x^2 - 4*x + 3" << endl;
    cout << endl;
    cout << "2. CARA MENGISI GALAT:" << endl;
    cout << "   - Sudah tersedia '0.' di depan, Anda tinggal melanjutkan" << endl;
    cout << "     angka di belakangnya" << endl;
    cout << "   - Contoh: jika ingin galat 0.0001, ketik: 0001" << endl;
    cout << "   - Contoh: jika ingin galat 0.001,  ketik: 001" << endl;
    cout << "   - Contoh: jika ingin galat 0.01,   ketik: 01" << endl;
    cout << endl;
    cout << "3. CARA MENGISI TEBAKAN AWAL x0:" << endl;
    cout << "   - Masukkan satu titik tebakan awal di dekat akar" << endl;
    cout << "   - Semakin dekat dengan akar, semakin cepat konvergen" << endl;
    cout << "   - Contoh: x0 = 1, x0 = 0, x0 = -2" << endl;
    cout << endl;
    cout << "------------------------------------------------------------" << endl;
    cout << endl;

    cout << "Fungsi : ";
    getline(cin, fungsi);

    cout << "Galat  : 0,";
    cin >> galatStr;

    // Proses input galat
    replace(galatStr.begin(), galatStr.end(), ',', '.');
    if (galatStr.empty()) {
        galat = 0.0;
    } else {
        try {
            galat = stod("0." + galatStr);
        } catch (...) {
            galat = 0.001; // default
        }
    }

    cout << "Masukkan tebakan awal x0: ";
    cin >> x0;

    cout << fixed << setprecision(6);
    cout << endl;

    // Algoritma Newton-Raphson
    double x_current = x0;
    double x_next = 0.0;
    double fx = 0.0;
    double fpx = 0.0;
    int iterasi = 0;
    double error = 0.0;

    cout << "-----------------------------------------------------------------------------------------" << endl;
    cout << setw(6) << "Iter"
         << setw(18) << "x"
         << setw(18) << "f(x)"
         << setw(18) << "f'(x)"
         << setw(18) << "x_next"
         << setw(18) << "Galat" << endl;
    cout << "-----------------------------------------------------------------------------------------" << endl;

    do {
        fx = parser.evaluate(fungsi, x_current);
        fpx = turunanNumerik(parser, fungsi, x_current);

        // Cek apakah turunan mendekati nol (agar tidak terjadi pembagian dengan nol)
        if (abs(fpx) < 1e-10) {
            cout << "-----------------------------------------------------------------------------------------" << endl;
            cout << "Error: Turunan mendekati nol! Metode Newton-Raphson gagal konvergen." << endl;
            cout << "Coba gunakan tebakan awal yang berbeda." << endl;
            return 0;
        }

        // Rumus Newton-Raphson: x1 = x0 - f(x0) / f'(x0)
        x_next = x_current - (fx / fpx);
        error = abs(x_next - x_current);

        cout << setw(6) << iterasi + 1
             << setw(18) << x_current
             << setw(18) << fx
             << setw(18) << fpx
             << setw(18) << x_next
             << setw(18) << error << endl;

        x_current = x_next;
        iterasi++;

        if (iterasi > 1000) {
            cout << "-----------------------------------------------------------------------------------------" << endl;
            cout << "Iterasi maksimum (1000) tercapai!" << endl;
            break;
        }

    } while (abs(fx) > galat);

    cout << "-----------------------------------------------------------------------------------------" << endl;
    cout << endl;
    cout << "Akar yang ditemukan   : x = " << x_current << endl;
    cout << "Nilai f(x)            : " << fx << endl;
    cout << "Galat akhir           : " << error << endl;
    cout << "Jumlah iterasi        : " << iterasi << endl;
    cout << endl;

    return 0;
}
